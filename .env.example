# TMDB API (https://www.themoviedb.org/settings/api)
# Provide EITHER a v3 API key OR a v4 read access token.
# If neither is set, the app falls back to bundled mock data so it still runs.

# v3 API key (short string)
TMDB_API_KEY=

# v4 read access token (long JWT-style string, starts with "eyJ...")
# TMDB_ACCESS_TOKEN=
